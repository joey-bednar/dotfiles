#!/bin/bash

set -euo pipefail
IFS=$'\n\t'

# Prompt sudo password if not running in docker container
set +u
if [[ -z "$DOCKER_CONTAINER" ]]; then
    sudo -v
fi
set -u

if __is_ubuntu; then

    # Core packages
    sudo apt install -y git vim less unzip usbutils xclip

elif __is_arch; then

    # Core packages
    __pacman_install linux-firmware git vim less zip unzip usbutils xclip reflector

    # Update mirrors using reflector:
    sudo reflector --protocol https --sort score --save /etc/pacman.d/mirrorlist

    if ! command -v yay &> /dev/null; then

        # Generate /etc/makepkg.conf
        sudo pacman -Syu pacman --noconfirm

        # Use sudo password to avoid being re-prompted
        cp /etc/makepkg.conf "/tmp/makepkg.conf"
        echo "PACMAN_AUTH=(sudo)" >> "/tmp/makepkg.conf"

        # Install yay
        sudo pacman -S --needed base-devel git --noconfirm
        git clone https://aur.archlinux.org/yay.git
        pushd yay > /dev/null
        makepkg --config "/tmp/makepkg.conf" -si --noconfirm
        popd > /dev/null
        rm -rf yay

    else
        echo "yay is already installed."
    fi


fi

